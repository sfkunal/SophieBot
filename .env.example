# Copy to .env for local reference, or to apps/worker/.dev.vars for wrangler dev.
# Production secrets: `wrangler secret put <NAME>` in apps/worker/

# Twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+15551234567

# Telegram (optional second channel; all three required when enabled)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=  # required — webhook returns 503 without it; pass as secret_token in setWebhook
TELEGRAM_BOT_USERNAME=

# OpenAI (intent extraction + reply personality)
OPENAI_API_KEY=sk-your-openai-api-key

# Google Calendar OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-worker.workers.dev/api/auth/google/callback

# Comma-separated E.164 allowlist — strictly enforced for SMS, onboarding, and API access
ALLOWED_PHONES=+15551234567,+15559876543

# Session signing for web dashboard (openssl rand -hex 32)
AUTH_SECRET=generate-with-openssl-rand-hex-32

# Public URLs (also set in apps/worker/wrangler.toml [vars] for non-secrets)
APP_URL=https://your-worker.workers.dev
WEB_URL=https://yourusername.github.io/SophieBot/

# GitHub Actions only (not needed locally):
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# WORKER_API_URL=https://your-worker.workers.dev
